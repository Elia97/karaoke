# URL del server Socket.IO. Lasciare vuoto in dev: il client connette
# same-origin (localhost:5173) e Vite proxa /socket.io a localhost:3000.
# In produzione su Vercel, settare al dominio pubblico del server Railway:
# i rewrites Vercel non supportano l'upgrade WebSocket, quindi Socket.IO
# bypassa Vercel e va direct sul server. L'autenticazione viaggia via
# token signed (vedi /api/auth/socket-token), non via cookie.
VITE_SOCKET_URL=
